# 給 Next.js App 用的 (效能好，支援 Serverless)
DATABASE_URL="postgres://[USER]:[PASSWORD]@[HOST]-pooler.singapore.aws.neon.tech/[DB_NAME]?sslmode=require"

# 給 Migration 或是 DBeaver 用的 (直接連線，不會被 Pool 擋住)
DIRECT_URL="postgres://[USER]:[PASSWORD]@[HOST].singapore.aws.neon.tech/[DB_NAME]?sslmode=require"

# Neon API Key (給 neonctl 或是 CI/CD 工具用的)
NEON_API_KEY="your-api-key-here"