generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL") 
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
  schemas    = ["audit", "public"]
}

/// 使用者  (承接 Auth 資訊)
model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?   // Auth.js 預設名稱
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?   // 使用者大頭貼
  username      String?   @unique
  tier          String?   @default("free")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  // --- 原本的關聯 ---
  checkpoints     Checkpoint[]
  memberships     ProjectMember[]
  projectMessages ProjectMessages[]
  projects        Project[]         @relation("ProjectOwner")
  
  // --- Auth.js 的關聯 ---
  accounts      Account[]
  sessions      Session[]

  @@map("users") // 資料庫裡的真實資料表名稱
  @@schema("public")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Project {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String            @map("owner_id") @db.Uuid
  title           String
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  checkpoints     Checkpoint[]
  liveDrafts      LiveDraft[]
  members         ProjectMember[]
  projectMessages ProjectMessages[]
  chapters        Chapter[]
  owner           User           @relation("ProjectOwner", fields: [ownerId], references: [id])
  categories      SettingCategory[]
  entities        SettingEntity[]

  @@index([ownerId])
  @@map("projects")
  @@schema("public")
}

model ProjectMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  project   Project   @relation(fields: [projectId], references: [id])
  user      User   @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
  @@schema("public")
}

model SettingCategory {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  name       String
  type       String?         @default("custom")
  orderIndex Float?          @default(0) @map("order_index")
  isPreset   Boolean?        @default(false) @map("is_preset")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  
  // 加上 onDelete: Cascade，如果這本小說被刪除了，底下的目錄也跟著刪除
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade) 
  entities   SettingEntity[]

  @@index([projectId, orderIndex])
  @@map("setting_categories")
  @@schema("public")
}

model SettingEntity {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  title      String
  content    Json?           @default("{}")
  orderIndex Float?          @default(0) @map("order_index")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)
  
  // 加上 onDelete: Cascade，確保目錄或小說被刪除時，實體也會一起消失
  category   SettingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([categoryId, orderIndex])
  @@index([projectId])
  @@map("setting_entities")
  @@schema("public")
}

model Checkpoint {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String?          @map("project_id") @db.Uuid
  authorId     String?          @map("author_id") @db.Uuid
  parentId     String?          @map("parent_id") @db.Uuid
  commitMsg    String?          @map("commit_msg")
  targetType   String           @map("target_type")
  targetId     String?          @map("target_id") @db.Uuid
  content      Json             
  createdAt    DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  analysis     AnalysisResult[]
  author       User?         @relation(fields: [authorId], references: [id])
  parent       Checkpoint?      @relation("CheckpointHistory", fields: [parentId], references: [id])
  children     Checkpoint[]     @relation("CheckpointHistory")
  project      Project?         @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([targetId])
  @@map("checkpoints")
  @@schema("public")
}

model AnalysisResult {
  id           BigInt                 @id @default(autoincrement())
  checkpointId String?                @map("checkpoint_id") @db.Uuid
  embedding    Unsupported("vector")?
  logicPayload Json?                  @default("{}") @map("logic_payload")
  createdAt    DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  checkpoint   Checkpoint?            @relation(fields: [checkpointId], references: [id])

  @@index([checkpointId])
  @@map("analysis_results")
  @@schema("public")
}

model LiveDraft {
  projectId  String    @map("project_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  rawContent Json      @map("raw_content")
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  project    Project   @relation(fields: [projectId], references: [id])

  @@id([projectId, userId])
  @@map("live_drafts")
  @@schema("public")
}

model OperationLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String    @map("table_name")
  recordId  String?   @map("record_id") @db.Uuid
  opType    String    @map("op_type")
  oldData   Json?     @map("old_data")
  newData   Json?     @map("new_data")
  userId    String?   @map("user_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("operation_logs")
  @@schema("audit")
}

model ProjectMessages {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content             String
  authorId            String           @map("author_id") @db.Uuid
  projectId           String           @map("project_id") @db.Uuid
  mentions            String[]         @db.Uuid
  referencedFile      String?          @map("referenced_file") @db.Uuid
  channelId           String           @map("channel_id")
  referencedMessageId String?          @map("referenced_message_id") @db.Uuid
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  users            User          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  projects            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectMessages     ProjectMessages? @relation("RecursiveMessages", fields: [referencedMessageId], references: [id], onDelete: Cascade)
  otherProjectMessages ProjectMessages[] @relation("RecursiveMessages")

  @@map("project_messages")
  @@schema("public")
}

model Chapter {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String    // 章節標題
  content     Json?     @default("{}") //  Tiptap 的內容存成 JSON 格式最完美
  orderIndex  Float     @default(0) @map("order_index") //  章節排序用
  wordCount   Int       @default(0) @map("word_count") // 字數統計
  status      String    @default("draft") // 狀態：例如 draft (草稿), published (發布)

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6) // 記錄最後編輯時間

  // 關聯設定：這個章節屬於哪一本小說 (Project)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 建立索引：加快「讀取特定小說的章節列表」並按順序排列的速度
  @@index([projectId, orderIndex])
  @@map("chapters")
  @@schema("public")
}