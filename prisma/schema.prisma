generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
 
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL") 
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
  schemas    = ["audit", "public"]
}

/// 使用者  (承接 Auth 資訊)
model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?   // Auth.js 預設名稱
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?   // 使用者大頭貼
  username      String?   @unique
  tier          String?   @default("free")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  
  // --- 原本的關聯 ---
  checkpoints     Checkpoint[]
  memberships     ProjectMember[]
  projectMessages ProjectMessages[]
  projects        Project[]         @relation("ProjectOwner")
  
  // --- Auth.js 的關聯 ---
  accounts      Account[]
  sessions      Session[]

  @@map("users") 
  @@schema("public")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token") @db.Text
  access_token      String? @map("access_token") @db.Text
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token") @db.Text
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Project {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String            @map("owner_id") @db.Uuid
  title           String
  worldSetting    Json?             @default("{}") @map("world_setting")
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime?         @map("created_at") @db.Timestamptz(6) @default(now())
  checkpoints     Checkpoint[]
  liveDrafts      LiveDraft[]
  members         ProjectMember[]
  projectMessages ProjectMessages[]
  chapters        Chapter[]
  owner           User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  categories      SettingCategory[]
  entities        SettingEntity[]

  @@index([ownerId])
  @@map("projects")
  @@schema("public")
}

model ProjectMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @map("created_at") @db.Timestamptz(6) @default(now())
  project   Project   @relation(fields: [projectId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
  @@schema("public")
}

model SettingCategory {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  name       String
  type       String?         @default("custom")
  orderIndex Float?          @default(0) @map("order_index")
  isPreset   Boolean?        @default(false) @map("is_preset")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @map("created_at") @db.Timestamptz(6) @default(now())
  
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade) 
  entities   SettingEntity[]

  @@index([projectId, orderIndex])
  @@map("setting_categories")
  @@schema("public")
}

model SettingEntity {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  title      String
  content    Json?           @default("{}") // 🌟 你的角色資料、稱號、Relations 關聯陣列通通存進這裡，非常完美！
  orderIndex Float?          @default(0) @map("order_index")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @map("created_at") @db.Timestamptz(6) @default(now())
  updatedAt  DateTime?       @map("updated_at") @db.Timestamptz(6) @default(now())
  embedding Unsupported("vector(1024)")? //<-補這個
  chapters   Chapter[]       @relation("ChapterSettings")
  
  category   SettingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  embedding Unsupported("vector(1024)")?

  @@index([categoryId, orderIndex])
  // 🌟 優化：新增 projectId 與 deletedAt 的索引，讓設定集加載與關係圖反查直接走索引
  @@index([projectId, deletedAt]) 
  @@map("setting_entities")
  @@schema("public")
}

model Checkpoint {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String?          @map("project_id") @db.Uuid
  authorId     String?          @map("author_id") @db.Uuid
  parentId     String?          @map("parent_id") @db.Uuid
  commitMsg    String?          @map("commit_msg")
  targetType   String           @map("target_type")
  targetId     String?          @map("target_id") @db.Uuid
  content      Json             
  deltaContent Json?            // 🌟 核心修正 1：補上選填的 deltaContent，消滅之前的 500 錯誤！
  createdAt    DateTime?        @map("created_at") @db.Timestamptz(6) @default(now())
  analysis     AnalysisResult[]
  author       User?            @relation(fields: [authorId], references: [id])
  parent       Checkpoint?      @relation("CheckpointHistory", fields: [parentId], references: [id])
  children     Checkpoint[]     @relation("CheckpointHistory")
  project      Project?         @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([targetId])
  @@map("checkpoints")
  @@schema("public")
}

model AnalysisResult {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid // 🌟 核心修正 3：改用 Uuid 主鍵，避開 Next.js API 的 BigInt 序列化報錯
  checkpointId String?                @map("checkpoint_id") @db.Uuid
  embedding    Unsupported("vector")?
  logicPayload Json?                  @default("{}") @map("logic_payload")
  createdAt    DateTime?              @map("created_at") @db.Timestamptz(6) @default(now())
  checkpoint   Checkpoint?            @relation(fields: [checkpointId], references: [id])

  @@index([checkpointId])
  @@map("analysis_results")
  @@schema("public")
}

model LiveDraft {
  projectId  String    @map("project_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  rawContent Json      @map("raw_content")
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6) @default(now())
  project    Project   @relation(fields: [projectId], references: [id])

  @@id([projectId, userId])
  @@map("live_drafts")
  @@schema("public")
}

model OperationLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String    @map("table_name")
  recordId  String?   @map("record_id") @db.Uuid
  opType    String    @map("op_type")
  oldData   Json?     @map("old_data")
  newData   Json?     @map("new_data")
  userId    String?   @map("user_id") @db.Uuid
  createdAt DateTime? @map("created_at") @db.Timestamptz(6) @default(now())

  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("operation_logs")
  @@schema("audit")
}

model ProjectMessages {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content             String
  authorId            String?          @map("author_id") @db.Uuid // 🌟 核心修正 2：改為選填 String?，才能安全對應下方 onDelete: SetNull
  projectId           String           @map("project_id") @db.Uuid
  mentions            String[]         @db.Uuid
  referencedFile      String?          @map("referenced_file") @db.Uuid
  channelId           String           @map("channel_id")
  referencedMessageId String?          @map("referenced_message_id") @db.Uuid
  createdAt           DateTime         @map("created_at") @db.Timestamptz(6) @default(now())
  users               User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  projects            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectMessages     ProjectMessages? @relation("RecursiveMessages", fields: [referencedMessageId], references: [id], onDelete: NoAction)
  otherProjectMessages ProjectMessages[] @relation("RecursiveMessages")

  @@map("project_messages")
  @@schema("public")
}

model Chapter {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  title      String    
  content    Json?     @default("{}") 
  deltaContent Json?   
  orderIndex Float     @default(0) @map("order_index") 
  wordCount  Int       @default(0) @map("word_count") 
  status     String    @default("draft") 

  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime  @map("created_at") @db.Timestamptz(6) @default(now())
  updatedAt  DateTime  @map("updated_at") @db.Timestamptz(6) @updatedAt 

  assignedSettings SettingEntity[] @relation("ChapterSettings")

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, orderIndex])
  @@map("chapters")
  @@schema("public")
}