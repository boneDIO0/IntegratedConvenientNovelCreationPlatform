generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
  schemas    = ["audit", "public"]
}

/// 使用者 (承接 Auth 資訊)
model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String? // Auth.js 預設名稱
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String? // 使用者大頭貼
  username      String?   @unique
  tier          String?   @default("free")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  // --- 原本的關聯 ---
  checkpoints     Checkpoint[]
  memberships     ProjectMember[]
  projectMessages ProjectMessages[]
  projects        Project[]         @relation("ProjectOwner")

  // --- Auth.js 的關聯 ---
  accounts Account[]
  sessions Session[]

  @@map("users")
  @@schema("public")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token") @db.Text
  access_token      String? @map("access_token") @db.Text
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token") @db.Text
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Project {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String            @map("owner_id") @db.Uuid
  title           String
  
  // 🌟 核心新增：用來儲存創作者自定義的時間曆法公式 (例如: { eraName: '廢墟紀元', baseYear: 1999 })
  worldSetting    Json?             @default("{}") @map("world_setting") 
  
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime?         @map("created_at") @db.Timestamptz(6) @default(now())
  checkpoints     Checkpoint[]
  liveDrafts      LiveDraft[]
  members         ProjectMember[]
  projectMessages ProjectMessages[]
  chapters        Chapter[]
  owner           User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  categories      SettingCategory[]
  entities        SettingEntity[]

  @@index([ownerId])
  @@map("projects")
  @@schema("public")
}

model ProjectMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @map("created_at") @db.Timestamptz(6) @default(now())
  project   Project   @relation(fields: [projectId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
  @@schema("public")
}

model SettingCategory {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  name       String
  type       String?         @default("custom")
  orderIndex Float?          @default(0) @map("order_index")
  isPreset   Boolean?        @default(false) @map("is_preset")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @map("created_at") @db.Timestamptz(6) @default(now())
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entities   SettingEntity[]

  @@index([projectId, orderIndex])
  @@map("setting_categories")
  @@schema("public")
}

model SettingEntity {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  title      String
  content    Json?           @default("{}")
  orderIndex Float?          @default(0) @map("order_index")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @map("created_at") @db.Timestamptz(6) @default(now())
  updatedAt  DateTime?       @map("updated_at") @db.Timestamptz(6) @default(now())

  // 🌟 修正：多對多關係的 @relation 識別名稱，雙方必須完全一致 (對齊 Chapter)
  chapters   Chapter[]       @relation("ChapterSettings")
  
  category   SettingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([categoryId, orderIndex])
  @@index([projectId, deletedAt])
  @@map("setting_entities")
  @@schema("public")
}

model Checkpoint {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String?          @map("project_id") @db.Uuid
  authorId     String?          @map("author_id") @db.Uuid
  parentId     String?          @map("parent_id") @db.Uuid
  commitMsg    String?          @map("commit_msg")
  targetType   String           @map("target_type")
  targetId     String?          @map("target_id") @db.Uuid
  content      Json
  deltaContent Json?
  createdAt    DateTime?        @map("created_at") @db.Timestamptz(6) @default(now())
  analysis     AnalysisResult[]
  author       User?            @relation(fields: [authorId], references: [id])
  parent       Checkpoint?      @relation("CheckpointHistory", fields: [parentId], references: [id])
  children     Checkpoint[]     @relation("CheckpointHistory")
  project      Project?         @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([targetId])
  @@map("checkpoints")
  @@schema("public")
}

model AnalysisResult {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checkpointId String?   @map("checkpoint_id") @db.Uuid
  embedding    Unsupported("vector")?
  logicPayload Json?     @default("{}") @map("logic_payload")
  createdAt    DateTime? @map("created_at") @db.Timestamptz(6) @default(now())
  checkpoint   Checkpoint? @relation(fields: [checkpointId], references: [id])

  @@index([checkpointId])
  @@map("analysis_results")
  @@schema("public")
}

model LiveDraft {
  projectId  String    @map("project_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  rawContent Json      @map("raw_content")
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6) @default(now())
  project    Project   @relation(fields: [projectId], references: [id])

  @@id([projectId, userId])
  @@map("live_drafts")
  @@schema("public")
}

model OperationLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String    @map("table_name")
  recordId  String?   @map("record_id") @db.Uuid
  opType    String    @map("op_type")
  oldData   Json?     @map("old_data")
  newData   Json?     @map("new_data")
  userId    String?   @map("user_id") @db.Uuid
  createdAt DateTime? @map("created_at") @db.Timestamptz(6) @default(now())

  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("operation_logs")
  @@schema("audit")
}

model ProjectMessages {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content             String
  authorId            String?          @map("author_id") @db.Uuid
  projectId           String           @map("project_id") @db.Uuid
  mentions            String[]         @db.Uuid
  referencedFile      String?          @map("referenced_file") @db.Uuid
  channelId           String           @map("channel_id")
  referencedMessageId String?          @map("referenced_message_id") @db.Uuid
  createdAt           DateTime         @map("created_at") @db.Timestamptz(6) @default(now())
  users               User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  projects            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // 🌟 建議將 onDelete 從 Cascade 改為 NoAction，避免母留言刪除時，子回覆慘遭全數株連
  projectMessages     ProjectMessages? @relation("RecursiveMessages", fields: [referencedMessageId], references: [id], onDelete: NoAction)
  otherProjectMessages ProjectMessages[] @relation("RecursiveMessages")

  @@map("project_messages")
  @@schema("public")
}

model Chapter {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  title        String
  content      Json?     @default("{}")
  deltaContent Json?
  orderIndex   Float     @default(0) @map("order_index")
  wordCount    Int       @default(0) @map("word_count")
  status       String    @default("draft")

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @map("created_at") @db.Timestamptz(6) @default(now())
  updatedAt DateTime  @map("updated_at") @db.Timestamptz(6) @updatedAt

  assignedSettings SettingEntity[] @relation("ChapterSettings")
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, orderIndex])
  @@map("chapters")
  @@schema("public")
}