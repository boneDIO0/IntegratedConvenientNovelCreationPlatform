// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")] // 啟用向量擴充功能
  schemas    = ["public", "audit"]
}

// --- [Public Schema] ---

/// 使用者 Profile (承接 Auth 資訊)
model Profile {
  id          String          @id @db.Uuid
  username    String?         @unique // 增加唯一索引，方便按用戶名查找
  tier        String?         @default("free")
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)

  projects    Project[]       @relation("ProjectOwner")
  memberships ProjectMember[]
  checkpoints Checkpoint[]
  liveDrafts  LiveDraft[]

  @@map("profiles")
  @@schema("public")
}

model Project {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String            @map("owner_id") @db.Uuid
  title       String
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)

  owner       Profile           @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  categories  SettingCategory[]
  entities    SettingEntity[]
  checkpoints Checkpoint[]
  liveDrafts  LiveDraft[]

  @@index([ownerId]) // 加速查找某人的所有專案
  @@map("projects")
  @@schema("public")
}

model ProjectMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  project   Project   @relation(fields: [projectId], references: [id])
  user      Profile   @relation(fields: [userId], references: [id])

  @@unique([projectId, userId]) // 重要：防止同一個用戶重複加入同一個專案
  @@index([userId])               // 加速查找「我參與的所有專案」
  @@map("project_members")
  @@schema("public")
}

model SettingCategory {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  name       String
  type       String?         @default("custom")
  orderIndex Float?          @default(0) @map("order_index")
  isPreset   Boolean?        @default(false) @map("is_preset")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)

  project    Project         @relation(fields: [projectId], references: [id])
  entities   SettingEntity[]

  @@index([projectId, orderIndex]) // 複合索引：加速按順序抓取專案下的分類
  @@map("setting_categories")
  @@schema("public")
}

model SettingEntity {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  categoryId String          @map("category_id") @db.Uuid
  title      String
  content    Json?           @default("{}")
  orderIndex Float?          @default(0) @map("order_index")
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)

  project    Project         @relation(fields: [projectId], references: [id])
  category   SettingCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId, orderIndex]) // 複合索引：加速顯示分類下的實體列表
  @@index([projectId])                // 全域搜尋專案內實體時有用
  @@map("setting_entities")
  @@schema("public")
}

model Checkpoint {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String?          @map("project_id") @db.Uuid
  authorId     String?          @map("author_id") @db.Uuid
  parentId     String?          @map("parent_id") @db.Uuid
  commitMsg    String?          @map("commit_msg")
  targetType   String           @map("target_type")
  targetId     String?          @map("target_id") @db.Uuid
  deltaContent Json             @map("delta_content")
  createdAt    DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)

  project      Project?         @relation(fields: [projectId], references: [id])
  author       Profile?         @relation(fields: [authorId], references: [id])
  parent       Checkpoint?      @relation("CheckpointHistory", fields: [parentId], references: [id])
  children     Checkpoint[]     @relation("CheckpointHistory")
  analysis     AnalysisResult[]

  @@index([projectId, createdAt]) // 加速查看專案的歷史變更線
  @@index([targetId])               // 快速找回特定章節/設定的歷史紀錄
  @@map("checkpoints")
  @@schema("public")
}

model AnalysisResult {
  id           BigInt      @id @default(autoincrement())
  checkpointId String?     @map("checkpoint_id") @db.Uuid
  embedding    Unsupported("vector(768)")? 
  logicPayload Json?       @default("{}") @map("logic_payload")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)

  checkpoint   Checkpoint? @relation(fields: [checkpointId], references: [id])

  @@index([checkpointId]) // 查找特定版本的分析結果
  @@map("analysis_results")
  @@schema("public")
}

model LiveDraft {
  projectId  String    @map("project_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  rawContent Json      @map("raw_content")
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  project    Project   @relation(fields: [projectId], references: [id])
  user       Profile   @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
  @@map("live_drafts")
  @@schema("public")
}

// --- [Audit Schema] ---

model OperationLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String    @map("table_name")
  recordId  String?   @map("record_id") @db.Uuid
  opType    String    @map("op_type")
  oldData   Json?     @map("old_data")
  newData   Json?     @map("new_data")
  userId    String?   @map("user_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tableName, recordId]) // 加速追蹤特定資料的變更歷史
  @@index([createdAt])             // 用於按時間排序日誌
  @@map("operation_logs")
  @@schema("audit")
}